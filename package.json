{
  "name": "guia-hoteles2026",
  "version": "1.0.0",
  "description": "Primer proyecto",
  "main": "index.html",
  "scripts": {
    "dev": "lite-server",
    "start": "concurrently \"npm run watch:scss \" \" npm run dev\" ",
    "test": "echo \"Error: no test specified\" && exit 1",
    "scss": "sass scss:css",
    "less": "lessc less/styles.less css/styles2.css",
    "watch:scss": "onchange 'scss/**/*.scss' -- npm run scss",
    "clean": "rimraf dist",
    "imagemin": "imagemin images/* --out-dir dist/images",
    "usemin": "usemin index.html -d dist --htmlmin -o dist/index.html && usemin about.html -d dist --htmlmin -o dist/about.html && usemin precios.html -d dist --htmlmin -o dist/precios.html && usemin contacto.html -d dist --htmlmin -o dist/contacto.html",
    "build": "npm run clean && npm run scss && npm run imagemin && npm run usemin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisandino2002/guia-hoteles2026.git"
  },
  "author": "Luis Andino",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/luisandino2002/guia-hoteles2026/issues"
  },
  "homepage": "https://github.com/luisandino2002/guia-hoteles2026#readme",
  "devDependencies": {
    "clean-css": "^5.3.3",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "grunt": "^1.6.1",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-sass": "^4.1.0",
    "html-minifier-terser": "^7.2.0",
    "imagemin-cli": "^8.0.0",
    "less": "^4.6.4",
    "lite-server": "^2.6.1",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "uglify-js": "^3.19.3",
    "usemin-cli": "^0.6.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "jquery": "^4.0.0",
    "popper.js": "^1.16.1"
  }
}
